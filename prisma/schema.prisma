model task {
  id                         String         @id
  merchantStoreId            String
  creatorId                  String
  assigneeId                 String?
  orderId                    String?
  customerId                 String?
  title                      String
  description                String?        @db.Text
  priority                   String         @default("MEDIUM")
  status                     String         @default("PENDING_CONFIRMATION")
  deadline                   DateTime?
  confirmedAt                DateTime?
  completedAt                DateTime?
  aiMetadata                 String?        @db.Text
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime
  attachments                String?        @db.Text
  readableId                 String?        @unique
  staffworklog               staffworklog[]
  user_task_assigneeIdTouser user?          @relation("task_assigneeIdTouser", fields: [assigneeId], references: [id], map: "Task_assigneeId_fkey")
  user_task_creatorIdTouser  user           @relation("task_creatorIdTouser", fields: [creatorId], references: [id], map: "Task_creatorId_fkey")
  customer                   customer?      @relation(fields: [customerId], references: [id], map: "Task_customerId_fkey")
  merchantstore              merchantstore  @relation(fields: [merchantStoreId], references: [id], map: "Task_merchantStoreId_fkey")
  order                      order?         @relation(fields: [orderId], references: [id], map: "Task_orderId_fkey")
  taskactivity               taskactivity[]
  taskmessage                taskmessage[]

  @@index([assigneeId], map: "Task_assigneeId_fkey")
  @@index([creatorId], map: "Task_creatorId_fkey")
  @@index([customerId], map: "Task_customerId_fkey")
  @@index([merchantStoreId], map: "Task_merchantStoreId_fkey")
  @@index([orderId], map: "Task_orderId_fkey")
}

model taskactivity {
  id        String   @id
  taskId    String
  userId    String?
  type      String
  message   String
  metadata  String?  @db.Text
  createdAt DateTime @default(now())
  task      task     @relation(fields: [taskId], references: [id], onDelete: Cascade, map: "TaskActivity_taskId_fkey")
  user      user?    @relation(fields: [userId], references: [id], map: "TaskActivity_userId_fkey")

  @@index([taskId], map: "TaskActivity_taskId_fkey")
  @@index([userId], map: "TaskActivity_userId_fkey")
}

model taskmessage {
  id        String   @id
  taskId    String
  userId    String
  content   String   @db.Text
  isAi      Boolean  @default(false)
  createdAt DateTime @default(now())
  task      task     @relation(fields: [taskId], references: [id], onDelete: Cascade, map: "TaskMessage_taskId_fkey")
  user      user     @relation(fields: [userId], references: [id], map: "TaskMessage_userId_fkey")

  @@index([taskId], map: "TaskMessage_taskId_fkey")
  @@index([userId], map: "TaskMessage_userId_fkey")
}

model unifiedconversation {
  id              String           @id
  merchantStoreId String
  externalId      String
  source          String
  customerName    String?
  customerAvatar  String?
  lastMessage     String?
  lastMessageAt   DateTime         @default(now())
  isAiEnabled     Boolean          @default(true)
  status          String           @default("OPEN")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  merchantstore   merchantstore    @relation(fields: [merchantStoreId], references: [id], map: "UnifiedConversation_merchantStoreId_fkey")
  unifiedmessage  unifiedmessage[]

  @@unique([merchantStoreId, externalId, source], map: "UnifiedConversation_merchantStoreId_externalId_source_key")
}

model unifiedmessage {
  id                  String              @id
  conversationId      String
  senderId            String
  senderName          String?
  content             String
  type                String              @default("TEXT")
  direction           String
  isAiGenerated       Boolean             @default(false)
  createdAt           DateTime            @default(now())
  unifiedconversation unifiedconversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "UnifiedMessage_conversationId_fkey")

  @@index([conversationId], map: "UnifiedMessage_conversationId_fkey")
}

model user {
  id                                   String                @id
  email                                String?               @unique(map: "User_email_key")
  name                                 String?
  phone                                String?
  password                             String
  role                                 String                @default("MERCHANT")
  customRoleId                         String?
  isOnboarded                          Boolean               @default(false)
  isActive                             Boolean               @default(true)
  currentSessionId                     String?
  createdAt                            DateTime              @default(now())
  updatedAt                            DateTime
  merchantStoreId                      String?
  sipStatus                            String                @default("OFFLINE")
  lastActiveAt                         DateTime              @default(now())
  branchId                             String?
  isArchived                           Boolean               @default(false)
  archivedAt                           DateTime?
  onboardingToken                      String?               @unique(map: "User_onboardingToken_key")
  onboardingTokenExpires               DateTime?
  resetToken                           String?               @unique(map: "User_resetToken_key")
  resetTokenExpires                    DateTime?
  isTwoFactorEnabled                   Boolean               @default(false)
  twoFactorSecret                      String?
  coverImage                           String?
  coverPosition                        Int                   @default(50)
  image                                String?
  readableId                           String?               @unique(map: "User_readableId_key")
  adminactionlog                       adminactionlog[]
  calllog_calllog_auditedByIdTouser    calllog[]             @relation("calllog_auditedByIdTouser")
  calllog_calllog_userIdTouser         calllog[]             @relation("calllog_userIdTouser")
  chatchannelmember                    chatchannelmember[]
  chatmoderationalert                  chatmoderationalert[]
  commissionpayout                     commissionpayout[]
  customer                             customer?
  customerprofile                      customerprofile?
  incident_incident_assignedToIdTouser incident[]            @relation("incident_assignedToIdTouser")
  incident_incident_userIdTouser       incident[]            @relation("incident_userIdTouser")
  incidentactivity                     incidentactivity[]
  incidentmessage                      incidentmessage[]
  internalmessage                      internalmessage[]
  inventorylog                         inventorylog[]
  order                                order[]
  orderactivity                        orderactivity[]
  paymenttransaction                   paymenttransaction[]
  staffcommission                      staffcommission[]
  staffdevice                          staffdevice[]
  staffprofile                         staffprofile?
  staffworklog                         staffworklog[]
  task_task_assigneeIdTouser           task[]                @relation("task_assigneeIdTouser")
  task_task_creatorIdTouser            task[]                @relation("task_creatorIdTouser")
  taskactivity                         taskactivity[]
  taskmessage                          taskmessage[]
  branch                               branch?               @relation(fields: [branchId], references: [id], map: "User_branchId_fkey")
  customRole                           role?                 @relation(fields: [customRoleId], references: [id], map: "User_customRoleId_fkey")
  merchantstore                        merchantstore?        @relation(fields: [merchantStoreId], references: [id], map: "User_merchantStoreId_fkey")

  @@index([branchId], map: "User_branchId_fkey")
  @@index([customRoleId], map: "User_customRoleId_fkey")
  @@index([merchantStoreId], map: "User_merchantStoreId_fkey")
}

model userstatuslog {
  id              String        @id
  userId          String
  merchantStoreId String
  status          String
  timestamp       DateTime      @default(now())
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "UserStatusLog_merchantStoreId_fkey")

  @@index([merchantStoreId], map: "UserStatusLog_merchantStoreId_fkey")
}

model warehouse {
  id                                                     String           @id
  name                                                   String
  location                                               String?
  isDefault                                              Boolean          @default(false)
  merchantStoreId                                        String
  branchId                                               String?
  createdAt                                              DateTime         @default(now())
  updatedAt                                              DateTime         @default(now())
  inventorylog                                           inventorylog[]
  returnrequest                                          returnrequest[]
  stocktransfer_stocktransfer_fromWarehouseIdTowarehouse stocktransfer[]  @relation("stocktransfer_fromWarehouseIdTowarehouse")
  stocktransfer_stocktransfer_toWarehouseIdTowarehouse   stocktransfer[]  @relation("stocktransfer_toWarehouseIdTowarehouse")
  branch                                                 branch?          @relation(fields: [branchId], references: [id], map: "Warehouse_branchId_fkey")
  merchantstore                                          merchantstore    @relation(fields: [merchantStoreId], references: [id], map: "Warehouse_merchantStoreId_fkey")
  warehousestock                                         warehousestock[]

  @@index([branchId], map: "Warehouse_branchId_fkey")
  @@index([merchantStoreId], map: "Warehouse_merchantStoreId_fkey")
}

model warehousestock {
  id          String    @id
  warehouseId String
  productId   String
  quantity    Int       @default(0)
  updatedAt   DateTime  @default(now())
  binLocation String?
  product     product   @relation(fields: [productId], references: [id], onDelete: Cascade, map: "WarehouseStock_productId_fkey")
  warehouse   warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade, map: "WarehouseStock_warehouseId_fkey")

  @@unique([warehouseId, productId], map: "WarehouseStock_warehouseId_productId_key")
  @@index([productId], map: "WarehouseStock_productId_fkey")
}

model wcconfig {
  id              String        @id
  merchantStoreId String        @unique(map: "WcConfig_merchantStoreId_key")
  websiteUrl      String
  consumerKey     String?
  consumerSecret  String?
  webhookSecret   String
  deductInventory Boolean       @default(true)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "WcConfig_merchantStoreId_fkey")
}

model systemsequence {
  id            String @id @default("GLOBAL")
  merchantCount Int    @default(0)
  adminCount    Int    @default(0)
}
