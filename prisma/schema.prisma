generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model abandonedcart {
  id                 String        @id
  merchantStoreId    String
  customerPhone      String?
  customerEmail      String?
  customerName       String?
  cartData           String?
  source             String        @default("WEB")
  lastReminderSentAt DateTime?
  status             String        @default("PENDING")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime
  merchantstore      merchantstore @relation(fields: [merchantStoreId], references: [id], map: "AbandonedCart_merchantStoreId_fkey")

  @@index([merchantStoreId], map: "AbandonedCart_merchantStoreId_idx")
  @@index([status], map: "AbandonedCart_status_idx")
}

model accountcategory {
  id                   String                 @id
  name                 String
  type                 String                 @default("EXPENSE")
  merchantStoreId      String
  merchantstore        merchantstore          @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade, map: "AccountCategory_merchantStoreId_fkey")
  budget               budget[]
  ledgertransaction    ledgertransaction[]
  recurringtransaction recurringtransaction[]

  @@index([merchantStoreId], map: "AccountCategory_merchantStoreId_fkey")
}

model accountingattachment {
  id                String            @id
  url               String
  transactionId     String
  ledgertransaction ledgertransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade, map: "AccountingAttachment_transactionId_fkey")

  @@index([transactionId], map: "AccountingAttachment_transactionId_fkey")
}

model adminactionlog {
  id              String   @id
  adminId         String
  merchantStoreId String?
  targetUserId    String?
  action          String
  entity          String
  entityId        String?
  metadata        String?  @db.Text
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())
  user            user     @relation(fields: [adminId], references: [id], map: "AdminActionLog_adminId_fkey")

  @@index([adminId], map: "AdminActionLog_adminId_fkey")
}

model aitransaction {
  id              String        @id
  merchantStoreId String
  amount          Float
  type            String
  description     String?
  createdAt       DateTime      @default(now())
  provider        String?
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "AiTransaction_merchantStoreId_fkey")

  @@index([merchantStoreId], map: "AiTransaction_merchantStoreId_fkey")
}

model branch {
  id                   String                 @id
  name                 String
  address              String?
  phone                String?
  managerId            String?
  merchantStoreId      String
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  merchantstore        merchantstore          @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade, map: "Branch_merchantStoreId_fkey")
  budget               budget[]
  businessaccount      businessaccount[]
  ledgertransaction    ledgertransaction[]
  order                order[]
  recurringtransaction recurringtransaction[]
  user                 user[]
  warehouse            warehouse[]

  @@index([merchantStoreId], map: "Branch_merchantStoreId_fkey")
}

model brand {
  id              String        @id
  name            String
  slug            String        @unique(map: "Brand_slug_key")
  logo            String?
  description     String?
  website         String?
  isFeatured      Boolean       @default(false)
  seoTitle        String?
  seoDescription  String?
  merchantStoreId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now())
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "Brand_merchantStoreId_fkey")
  product         product[]

  @@index([merchantStoreId], map: "Brand_merchantStoreId_fkey")
}

model budget {
  id              String          @id
  amount          Float
  period          String          @default("MONTHLY")
  startDate       DateTime
  endDate         DateTime
  branchId        String?
  categoryId      String
  merchantStoreId String
  branch          branch?         @relation(fields: [branchId], references: [id], map: "Budget_branchId_fkey")
  accountcategory accountcategory @relation(fields: [categoryId], references: [id], map: "Budget_categoryId_fkey")
  merchantstore   merchantstore   @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade, map: "Budget_merchantStoreId_fkey")

  @@unique([merchantStoreId, branchId, categoryId, startDate], map: "Budget_merchantStoreId_branchId_categoryId_startDate_key")
  @@index([branchId], map: "Budget_branchId_fkey")
  @@index([categoryId], map: "Budget_categoryId_fkey")
}

model businessaccount {
  id                String              @id
  name              String
  type              String              @default("BANK")
  balance           Float               @default(0)
  accountNumber     String?
  bankName          String?
  branchId          String?
  merchantStoreId   String
  branch            branch?             @relation(fields: [branchId], references: [id], map: "BusinessAccount_branchId_fkey")
  merchantstore     merchantstore       @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade, map: "BusinessAccount_merchantStoreId_fkey")
  ledgertransaction ledgertransaction[]

  @@index([branchId], map: "BusinessAccount_branchId_fkey")
  @@index([merchantStoreId], map: "BusinessAccount_merchantStoreId_fkey")
}

model calllog {
  id                             String        @id
  merchantStoreId                String
  userId                         String
  orderId                        String?
  from                           String
  to                             String
  duration                       Int           @default(0)
  recordingUrl                   String?
  direction                      String        @default("OUTBOUND")
  status                         String        @default("COMPLETED")
  aiSummary                      String?
  sentiment                      String?       @default("NEUTRAL")
  transcription                  String?
  callType                       String        @default("VOICE")
  isMissed                       Boolean       @default(false)
  auditNote                      String?
  rating                         Int?          @default(0)
  auditedAt                      DateTime?
  auditedById                    String?
  createdAt                      DateTime      @default(now())
  user_calllog_auditedByIdTouser user?         @relation("calllog_auditedByIdTouser", fields: [auditedById], references: [id], map: "CallLog_auditedById_fkey")
  merchantstore                  merchantstore @relation(fields: [merchantStoreId], references: [id], map: "CallLog_merchantStoreId_fkey")
  order                          order?        @relation(fields: [orderId], references: [id], map: "CallLog_orderId_fkey")
  user_calllog_userIdTouser      user          @relation("calllog_userIdTouser", fields: [userId], references: [id], map: "CallLog_userId_fkey")

  @@index([auditedById], map: "CallLog_auditedById_fkey")
  @@index([merchantStoreId], map: "CallLog_merchantStoreId_fkey")
  @@index([orderId], map: "CallLog_orderId_fkey")
  @@index([userId], map: "CallLog_userId_fkey")
}

model campaignlog {
  id                String            @id
  campaignId        String
  customerId        String
  status            String
  error             String?
  createdAt         DateTime          @default(now())
  marketingcampaign marketingcampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade, map: "CampaignLog_campaignId_fkey")

  @@index([campaignId], map: "CampaignLog_campaignId_fkey")
}

model category {
  id              String        @id
  name            String
  slug            String        @unique(map: "Category_slug_key")
  description     String?
  image           String?
  isFeatured      Boolean       @default(false)
  seoTitle        String?
  seoDescription  String?
  parentId        String?
  merchantStoreId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now())
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "Category_merchantStoreId_fkey")
  category        category?     @relation("categoryTocategory", fields: [parentId], references: [id], map: "Category_parentId_fkey")
  other_category  category[]    @relation("categoryTocategory")
  product         product[]

  @@index([merchantStoreId], map: "Category_merchantStoreId_fkey")
  @@index([parentId], map: "Category_parentId_fkey")
}

model chatchannel {
  id                String              @id
  name              String?
  participant1Id    String?
  participant2Id    String?
  type              String              @default("ORDER")
  orderId           String?             @unique(map: "ChatChannel_orderId_key")
  merchantStoreId   String
  createdAt         DateTime            @default(now())
  merchantstore     merchantstore       @relation(fields: [merchantStoreId], references: [id], map: "ChatChannel_merchantStoreId_fkey")
  order             order?              @relation(fields: [orderId], references: [id], map: "ChatChannel_orderId_fkey")
  chatchannelmember chatchannelmember[]
  internalmessage   internalmessage[]

  @@index([merchantStoreId], map: "ChatChannel_merchantStoreId_fkey")
}

model chatchannelmember {
  id          String      @id
  channelId   String
  userId      String
  role        String      @default("MEMBER")
  createdAt   DateTime    @default(now())
  chatchannel chatchannel @relation(fields: [channelId], references: [id], onDelete: Cascade, map: "ChatChannelMember_channelId_fkey")
  user        user        @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ChatChannelMember_userId_fkey")

  @@unique([channelId, userId], map: "ChatChannelMember_channelId_userId_key")
  @@index([userId], map: "ChatChannelMember_userId_fkey")
}

model chatmoderationalert {
  id              String        @id
  merchantStoreId String
  senderId        String
  messageContent  String
  aiReason        String
  severity        String        @default("LOW")
  createdAt       DateTime      @default(now())
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "ChatModerationAlert_merchantStoreId_fkey")
  user            user          @relation(fields: [senderId], references: [id], map: "ChatModerationAlert_senderId_fkey")

  @@index([merchantStoreId], map: "ChatModerationAlert_merchantStoreId_fkey")
  @@index([senderId], map: "ChatModerationAlert_senderId_fkey")
}

model commissionpayout {
  id              String        @id
  userId          String
  staffProfileId  String?
  merchantStoreId String
  amount          Float
  method          String
  reference       String?
  status          String        @default("COMPLETED")
  paidAt          DateTime      @default(now())
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "CommissionPayout_merchantStoreId_fkey")
  staffprofile    staffprofile? @relation(fields: [staffProfileId], references: [id], map: "CommissionPayout_staffProfileId_fkey")
  user            user          @relation(fields: [userId], references: [id], map: "CommissionPayout_userId_fkey")

  @@index([merchantStoreId], map: "CommissionPayout_merchantStoreId_fkey")
  @@index([staffProfileId], map: "CommissionPayout_staffProfileId_fkey")
  @@index([userId], map: "CommissionPayout_userId_fkey")
}

model commissionrule {
  id              String        @id
  merchantStoreId String
  name            String
  type            String        @default("PERCENTAGE")
  value           Float
  thresholdAmount Float         @default(0)
  bonusValue      Float         @default(0)
  isRecurring     Boolean       @default(false)
  isActive        Boolean       @default(true)
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "CommissionRule_merchantStoreId_fkey")

  @@index([merchantStoreId], map: "CommissionRule_merchantStoreId_fkey")
}

model coupon {
  id                String             @id
  code              String             @unique(map: "Coupon_code_key")
  discountValue     Float
  type              String             @default("PERCENTAGE")
  usageCount        Int                @default(0)
  maxUsage          Int?
  expiryDate        DateTime?
  merchantStoreId   String
  campaignId        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime
  marketingcampaign marketingcampaign? @relation(fields: [campaignId], references: [id], map: "Coupon_campaignId_fkey")
  merchantstore     merchantstore      @relation(fields: [merchantStoreId], references: [id], map: "Coupon_merchantStoreId_fkey")
  order             order[]

  @@index([campaignId], map: "Coupon_campaignId_fkey")
  @@index([merchantStoreId], map: "Coupon_merchantStoreId_fkey")
}

model courierconfig {
  id                  String        @id
  providerName        String
  apiKey              String?
  apiSecret           String?
  type                String        @default("API")
  trackingUrlTemplate String?
  isActive            Boolean       @default(true)
  merchantStoreId     String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime
  merchantstore       merchantstore @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade, map: "CourierConfig_merchantStoreId_fkey")

  @@unique([merchantStoreId, providerName], map: "CourierConfig_merchantStoreId_providerName_key")
}

model customer {
  id              String          @id
  name            String?
  phone           String
  email           String?
  merchantStoreId String
  userId          String?         @unique(map: "Customer_userId_key")
  totalSpend      Float           @default(0)
  orderCount      Int             @default(0)
  loyaltyPoints   Int             @default(0)
  tags            String          @default("NEW")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  readableId      String?         @unique
  merchantstore   merchantstore   @relation(fields: [merchantStoreId], references: [id], map: "Customer_merchantStoreId_fkey")
  user            user?           @relation(fields: [userId], references: [id], map: "Customer_userId_fkey")
  order           order[]
  productreview   productreview[]
  task            task[]

  @@unique([merchantStoreId, phone], map: "Customer_merchantStoreId_phone_key")
}

model customerprofile {
  id            String  @id
  userId        String  @unique(map: "CustomerProfile_userId_key")
  loyaltyPoints Int     @default(0)
  totalOrders   Int     @default(0)
  savedAddress  String?
  user          user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "CustomerProfile_userId_fkey")
}

model devicelicense {
  id              String        @id
  staffDeviceId   String        @unique(map: "DeviceLicense_staffDeviceId_key")
  merchantStoreId String
  price           Float
  activatedAt     DateTime      @default(now())
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "DeviceLicense_merchantStoreId_fkey")
  staffdevice     staffdevice   @relation(fields: [staffDeviceId], references: [id], onDelete: Cascade, map: "DeviceLicense_staffDeviceId_fkey")

  @@index([merchantStoreId], map: "DeviceLicense_merchantStoreId_fkey")
}

model emailtemplate {
  id        String   @id
  type      String   @unique(map: "EmailTemplate_type_key")
  name      String
  subject   String
  body      String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model facebookconfig {
  id                String        @id
  merchantStoreId   String        @unique(map: "FacebookConfig_merchantStoreId_key")
  pageId            String?
  accessToken       String?
  isActive          Boolean       @default(false)
  autoReplyComments Boolean       @default(true)
  keywordDmEnabled  Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime
  adAccountId       String?
  capiToken         String?
  pixelId           String?
  testEventCode     String?
  merchantstore     merchantstore @relation(fields: [merchantStoreId], references: [id], map: "FacebookConfig_merchantStoreId_fkey")
}

model flashsale {
  id              String          @id
  merchantStoreId String
  name            String
  description     String?
  startTime       DateTime
  endTime         DateTime
  status          String          @default("PENDING")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  merchantstore   merchantstore   @relation(fields: [merchantStoreId], references: [id], map: "FlashSale_merchantStoreId_fkey")
  flashsaleitem   flashsaleitem[]

  @@index([merchantStoreId], map: "FlashSale_merchantStoreId_fkey")
}

model flashsaleitem {
  id          String    @id
  flashSaleId String
  productId   String
  salePrice   Float
  stockLimit  Int
  soldCount   Int       @default(0)
  flashsale   flashsale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade, map: "FlashSaleItem_flashSaleId_fkey")
  product     product   @relation(fields: [productId], references: [id], map: "FlashSaleItem_productId_fkey")

  @@unique([flashSaleId, productId], map: "FlashSaleItem_flashSaleId_productId_key")
  @@index([productId], map: "FlashSaleItem_productId_fkey")
}

model googlesheetsconfig {
  id              String        @id
  merchantStoreId String        @unique(map: "GoogleSheetsConfig_merchantStoreId_key")
  accessToken     String?
  refreshToken    String?
  expiryDate      BigInt?
  spreadsheetId   String?
  sheetName       String        @default("Orders")
  isActive        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "GoogleSheetsConfig_merchantStoreId_fkey")
}

model incident {
  id                               String             @id
  number                           String             @unique(map: "Incident_number_key")
  subject                          String
  description                      String
  category                         String             @default("TECHNICAL")
  priority                         String             @default("MEDIUM")
  impact                           String             @default("3")
  urgency                          String             @default("3")
  status                           String             @default("NEW")
  contactPhone                     String?
  resolutionCode                   String?
  resolutionNotes                  String?
  resolvedAt                       DateTime?
  closedAt                         DateTime?
  merchantStoreId                  String
  userId                           String
  assignedToId                     String?
  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime
  user_incident_assignedToIdTouser user?              @relation("incident_assignedToIdTouser", fields: [assignedToId], references: [id], map: "Incident_assignedToId_fkey")
  merchantstore                    merchantstore      @relation(fields: [merchantStoreId], references: [id], map: "Incident_merchantStoreId_fkey")
  user_incident_userIdTouser       user               @relation("incident_userIdTouser", fields: [userId], references: [id], map: "Incident_userId_fkey")
  incidentactivity                 incidentactivity[]
  incidentmessage                  incidentmessage[]

  @@index([assignedToId], map: "Incident_assignedToId_fkey")
  @@index([merchantStoreId], map: "Incident_merchantStoreId_fkey")
  @@index([userId], map: "Incident_userId_fkey")
}

model incidentactivity {
  id         String   @id
  incidentId String
  userId     String?
  type       String
  message    String
  createdAt  DateTime @default(now())
  incident   incident @relation(fields: [incidentId], references: [id], onDelete: Cascade, map: "IncidentActivity_incidentId_fkey")
  user       user?    @relation(fields: [userId], references: [id], map: "IncidentActivity_userId_fkey")

  @@index([incidentId], map: "IncidentActivity_incidentId_fkey")
  @@index([userId], map: "IncidentActivity_userId_fkey")
}

model incidentmessage {
  id            String   @id
  incidentId    String
  userId        String
  content       String
  isInternal    Boolean  @default(false)
  attachmentUrl String?
  createdAt     DateTime @default(now())
  incident      incident @relation(fields: [incidentId], references: [id], onDelete: Cascade, map: "IncidentMessage_incidentId_fkey")
  user          user     @relation(fields: [userId], references: [id], map: "IncidentMessage_userId_fkey")

  @@index([incidentId], map: "IncidentMessage_incidentId_fkey")
  @@index([userId], map: "IncidentMessage_userId_fkey")
}

model incrementrule {
  id               String       @id
  staffProfileId   String
  conditionType    String
  conditionValue   Float
  incrementPercent Float
  isApplied        Boolean      @default(false)
  staffprofile     staffprofile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade, map: "IncrementRule_staffProfileId_fkey")

  @@index([staffProfileId], map: "IncrementRule_staffProfileId_fkey")
}

model internalmessage {
  id              String      @id
  channelId       String
  senderId        String
  content         String
  attachmentUrls  String?
  isFlagged       Boolean     @default(false)
  flagReason      String?
  aiModerationLog String?
  createdAt       DateTime    @default(now())
  chatchannel     chatchannel @relation(fields: [channelId], references: [id], map: "InternalMessage_channelId_fkey")
  user            user        @relation(fields: [senderId], references: [id], map: "InternalMessage_senderId_fkey")

  @@index([channelId], map: "InternalMessage_channelId_fkey")
  @@index([senderId], map: "InternalMessage_senderId_fkey")
}

model inventorylog {
  id              String        @id
  merchantStoreId String
  warehouseId     String
  productId       String
  type            String
  quantity        Int
  previousStock   Int
  newStock        Int
  reason          String?
  referenceId     String?
  userId          String
  createdAt       DateTime      @default(now())
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "InventoryLog_merchantStoreId_fkey")
  product         product       @relation(fields: [productId], references: [id], map: "InventoryLog_productId_fkey")
  user            user          @relation(fields: [userId], references: [id], map: "InventoryLog_userId_fkey")
  warehouse       warehouse     @relation(fields: [warehouseId], references: [id], map: "InventoryLog_warehouseId_fkey")

  @@index([merchantStoreId], map: "InventoryLog_merchantStoreId_fkey")
  @@index([productId], map: "InventoryLog_productId_fkey")
  @@index([userId], map: "InventoryLog_userId_fkey")
  @@index([warehouseId], map: "InventoryLog_warehouseId_fkey")
}

model invoice {
  id              String        @id
  merchantStoreId String
  amount          Float
  status          String        @default("PENDING")
  billingCycle    String
  dueDate         DateTime
  paidAt          DateTime?
  invoiceUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "Invoice_merchantStoreId_fkey")
  invoiceitem     invoiceitem[]

  @@index([merchantStoreId], map: "Invoice_merchantStoreId_fkey")
}

model invoiceitem {
  id        String  @id
  invoiceId String
  userId    String?
  name      String
  amount    Float
  days      Int
  invoice   invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade, map: "InvoiceItem_invoiceId_fkey")

  @@index([invoiceId], map: "InvoiceItem_invoiceId_fkey")
}

model knowledgebase {
  id              String        @id
  merchantStoreId String
  fileName        String
  fileUrl         String
  fileType        String
  content         String?
  isIndexed       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  merchantstore   merchantstore @relation(fields: [merchantStoreId], references: [id], map: "KnowledgeBase_merchantStoreId_fkey")

  @@index([merchantStoreId], map: "KnowledgeBase_merchantStoreId_fkey")
}

model ledgertransaction {
  id                   String                 @id
  amount               Float
  type                 String                 @default("EXPENSE")
  description          String?
  date                 DateTime               @default(now())
  branchId             String?
  categoryId           String
  accountId            String?
  merchantStoreId      String
  referenceId          String?
  accountingattachment accountingattachment[]
  businessaccount      businessaccount?       @relation(fields: [accountId], references: [id], map: "LedgerTransaction_accountId_fkey")
  branch               branch?                @relation(fields: [branchId], references: [id], map: "LedgerTransaction_branchId_fkey")
  accountcategory      accountcategory        @relation(fields: [categoryId], references: [id], map: "LedgerTransaction_categoryId_fkey")
  merchantstore        merchantstore          @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade, map: "LedgerTransaction_merchantStoreId_fkey")

  @@index([accountId], map: "LedgerTransaction_accountId_fkey")
  @@index([branchId], map: "LedgerTransaction_branchId_fkey")
  @@index([categoryId], map: "LedgerTransaction_categoryId_fkey")
  @@index([merchantStoreId], map: "LedgerTransaction_merchantStoreId_fkey")
}

model marketingcampaign {
  id               String        @id
  name             String
  type             String        @default("SMS")
  status           String        @default("DRAFT")
  content          String
  targetCriteria   String?
  scheduledAt      DateTime?
  totalTarget      Int           @default(0)
  sentCount        Int           @default(0)
  totalCost        Float         @default(0)
  revenueGenerated Float         @default(0)
  merchantStoreId  String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime
  campaignlog      campaignlog[]
  coupon           coupon[]
  merchantstore    merchantstore @relation(fields: [merchantStoreId], references: [id], map: "MarketingCampaign_merchantStoreId_fkey")

  @@index([merchantStoreId], map: "MarketingCampaign_merchantStoreId_fkey")
}

model merchantsequence {
  id              String        @id
  merchantStoreId String        @unique
  customerSeq     Int           @default(0)
  orderSeq        Int           @default(0)
  taskSeq         Int           @default(0)
  staffSeq        Int           @default(0)
  merchantStore   merchantstore @relation(fields: [merchantStoreId], references: [id])
}

model merchantstore {
  id                   String                 @id
  name                 String
