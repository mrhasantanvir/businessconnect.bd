  siteTitle           String   @default("BusinessConnect.bd")
  siteDescription     String?
  metaKeywords        String?
  ogImage             String?
  
  // Cloud Storage Settings
  storageProvider     String   @default("LOCAL") // "LOCAL", "S3", "WASABI", "AZURE", "GCP"
  storageBucket       String?
  storageEndpoint     String?
  storageAccessKey    String?
  storageSecretKey    String?
  storageCdnUrl       String?

  updatedAt           DateTime @updatedAt
  googleClientId      String?
  googleClientSecret  String?
  googleRedirectUri   String?  @default("http://localhost:3030/api/auth/google/callback")
  fbAppId             String?
