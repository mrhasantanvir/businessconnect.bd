  whatsappToken          String?
  whatsappPhoneId        String?
  openaiApiKey           String?
  openaiModel            String   @default("gpt-4o")
  openRouterKey          String?
  openRouterModel        String   @default("openai/gpt-3.5-turbo")
  geminiKey              String?
  geminiModel            String   @default("gemini-1.5-pro")
  aiProviderPriority     String   @default("OPENAI,GEMINI,DEEPSEEK,OPENROUTER")
  googleVisionKey        String?
  fbAppSecret            String?
  aiCreditPrice          Float    @default(0.5)
  staffSubscriptionPrice Float    @default(300)
  siteTitle              String   @default("BusinessConnect.bd")
  siteDescription        String?
  metaKeywords           String?
  ogImage                String?
  storageProvider        String   @default("LOCAL")
  storageBucket          String?
  storageEndpoint        String?
  storageAccessKey       String?
  storageSecretKey       String?
  storageCdnUrl          String?
  updatedAt              DateTime
  googleClientId         String?
  googleClientSecret     String?
  googleRedirectUri      String?  @default("http://localhost:3030/api/auth/google/callback")
  fbAppId                String?
  fbRedirectUri          String?  @default("http://localhost:3030/api/auth/facebook/callback")
  deepseekKey            String?
  deepseekModel          String   @default("deepseek-chat")
  groqKey                String?
