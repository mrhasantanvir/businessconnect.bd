model PaymentTransaction {
  id              String        @id @default(cuid())
  merchantStoreId String
  userId          String?
  amount          Float
  credits         Float         @default(0)
  currency        String        @default("BDT")
  paymentMethod   String        @default("UNSPECIFIED")
  type            String
  status          String        @default("PENDING")
  trxId           String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User?         @relation(fields: [userId], references: [id])
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model AbandonedCart {
  id                 String        @id @default(cuid())
  merchantStoreId    String
  customerPhone      String?
  customerEmail      String?
  customerName       String?
  cartData           String?
  source             String        @default("WEB")
  lastReminderSentAt DateTime?
  status             String        @default("PENDING")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  merchantStore      MerchantStore @relation(fields: [merchantStoreId], references: [id])

  @@index([merchantStoreId])
  @@index([status])
}

model PayoutRequest {
  id              String        @id @default(cuid())
  merchantStoreId String
  amount          Float
  method          String
  details         String
  status          String        @default("PENDING")
  processedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model WcConfig {
  id              String        @id @default(cuid())
  merchantStoreId String        @unique
  websiteUrl      String
  consumerKey     String?
  consumerSecret  String?
  webhookSecret   String        @default(cuid())
  deductInventory Boolean       @default(true)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model GoogleSheetsConfig {
  id              String        @id @default(cuid())
  merchantStoreId String        @unique
  accessToken     String?
  refreshToken    String?
  expiryDate      BigInt?
  spreadsheetId   String?
  sheetName       String        @default("Orders")
  isActive        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model ReportSubscription {
  id              String        @id @default(cuid())
  merchantStoreId String
  reportType      String        @default("SALES")
  frequency       String        @default("WEEKLY")
  email           String
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastSentAt      DateTime?
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model ShippingRate {
  id                       String        @id @default(cuid())
  merchantStoreId          String
  courierName              String
  courierLogo              String?
  insideDhaka              Float         @default(60)
  outsideDhaka             Float         @default(120)
  subDhaka                 Float         @default(100)
  perKgInsideDhaka         Float         @default(0)
  perKgOutsideDhaka        Float         @default(0)
  perLiterInsideDhaka      Float         @default(0)
  perLiterOutsideDhaka     Float         @default(0)
  homeDeliveryInsideDhaka  Float         @default(0)
  homeDeliveryOutsideDhaka Float         @default(0)
  baseWeightKg             Float         @default(1)
  extraWeightFee           Float         @default(20)
  liquidSurcharge          Float         @default(0)
  fragileSurcharge         Float         @default(0)
  isActive                 Boolean       @default(true)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  merchantStore            MerchantStore @relation(fields: [merchantStoreId], references: [id])

  @@unique([merchantStoreId, courierName])
}

model PaymentConfig {
  id              String        @id @default(cuid())
  merchantStoreId String
  provider        String
  apiKey          String?
  apiSecret       String?
  merchantId      String?
  publicKey       String?
  privateKey      String?
  storeId         String?
  storePass       String?
  isTestMode      Boolean       @default(true)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)

  @@unique([merchantStoreId, provider])
}

model SmsConfig {
  id              String        @id @default(cuid())
  merchantStoreId String
  provider        String
  apiKey          String?
  senderId        String?
  apiUrl          String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)

  @@unique([merchantStoreId, provider])
}

model SipConfig {
  id              String        @id @default(cuid())
  merchantStoreId String        @unique
  username        String
  password        String
  domain          String
  port            Int           @default(5060)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
}


model CommissionRule {
  id              String        @id @default(cuid())
  merchantStoreId String
  name            String
  type            String        @default("PERCENTAGE") // PERCENTAGE, FIXED
  value           Float
  thresholdAmount Float         @default(0) // Minimum sales to trigger bonus
  bonusValue      Float         @default(0) // Extra bonus if threshold met
  isRecurring     Boolean       @default(false)
  isActive        Boolean       @default(true)
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model StaffCommission {
  id              String        @id @default(cuid())
  userId          String
  staffProfileId  String?
  orderId         String
  merchantStoreId String
  amount          Float
  type            String        @default("SALE") // SALE, BONUS, RECURRING
  status          String        @default("PENDING") // PENDING, APPROVED, PAID
  earnedAt        DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id])
  staffProfile    StaffProfile? @relation(fields: [staffProfileId], references: [id])
  order           Order?        @relation(fields: [orderId], references: [id])
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model CommissionPayout {
  id              String        @id @default(cuid())
  userId          String
  staffProfileId  String?
  merchantStoreId String
  amount          Float
  method          String
  reference       String?
  status          String        @default("COMPLETED")
  paidAt          DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id])
  staffProfile    StaffProfile? @relation(fields: [staffProfileId], references: [id])
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model AccountCategory {
  id              String              @id @default(cuid())
  name            String
  type            String              @default("EXPENSE") // INCOME, EXPENSE
  merchantStoreId String
  merchantStore   MerchantStore       @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  transactions    LedgerTransaction[]
  budgets         Budget[]
  recurringTransactions RecurringTransaction[]
}

model LedgerTransaction {
  id              String                 @id @default(cuid())
  amount          Float
  type            String                 @default("EXPENSE") // INCOME, EXPENSE
  description     String?
  date            DateTime               @default(now())
  branchId        String?
  categoryId      String
  accountId       String?
  merchantStoreId String
  referenceId     String?
  branch          Branch?                @relation(fields: [branchId], references: [id])
  category        AccountCategory        @relation(fields: [categoryId], references: [id])
  account         BusinessAccount?       @relation(fields: [accountId], references: [id])
  merchantStore   MerchantStore          @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  attachments     AccountingAttachment[]
}

model BusinessAccount {
  id              String              @id @default(cuid())
  name            String
  type            String              @default("BANK") // BANK, CASH
  balance         Float               @default(0)
  accountNumber   String?
  bankName        String?
  branchId        String?
  merchantStoreId String
  branch          Branch?             @relation(fields: [branchId], references: [id])
  merchantStore   MerchantStore       @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
  transactions    LedgerTransaction[]
}

model AccountingAttachment {
  id            String            @id @default(cuid())
  url           String
  transactionId String
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Budget {
  id              String          @id @default(cuid())
  amount          Float
  period          String          @default("MONTHLY")
  startDate       DateTime
  endDate         DateTime
  branchId        String?
  categoryId      String
  merchantStoreId String
  branch          Branch?         @relation(fields: [branchId], references: [id])
  category        AccountCategory @relation(fields: [categoryId], references: [id])
  merchantStore   MerchantStore   @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)

  @@unique([merchantStoreId, branchId, categoryId, startDate])
}

model RecurringTransaction {
  id              String          @id @default(cuid())
  amount          Float
  type            String
  description     String?
  frequency       String          @default("MONTHLY") // WEEKLY, MONTHLY, YEARLY
  nextRunDate     DateTime
  isActive        Boolean         @default(true)
  branchId        String?
  categoryId      String
  merchantStoreId String
  branch          Branch?         @relation(fields: [branchId], references: [id])
  category        AccountCategory @relation(fields: [categoryId], references: [id])
  merchantStore   MerchantStore   @relation(fields: [merchantStoreId], references: [id], onDelete: Cascade)
}
model Otp {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  type      String   @unique // e.g., "STORE_ACTIVATED", "STORE_REJECTED", "DOCUMENTS_REUPLOAD"
  name      String   // e.g., "Store Activation Email"
  subject   String
  body      String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id              String        @id @default(cuid())
  merchantStoreId String
  amount          Float
  status          String        @default("PENDING") // PENDING, PAID, OVERDUE, CANCELLED
  billingCycle    String        // e.g., "2026-04"
  dueDate         DateTime
  paidAt          DateTime?
  invoiceUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
  items           InvoiceItem[]
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  userId    String? // Optional: Link to the specific staff user if needed
  name      String  // e.g., "Staff Subscription - Tanvir"
  amount    Float
  days      Int     // Number of days charged
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model UserStatusLog {
  id              String        @id @default(cuid())
  userId          String
  merchantStoreId String
  status          String        // ACTIVE, DEACTIVE
  timestamp       DateTime      @default(now())
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model AdminActionLog {
  id              String        @id @default(cuid())
  adminId         String        // User ID of the admin who performed the action
  merchantStoreId String?       // Optional: Merchant store affected
  targetUserId    String?       // Optional: User affected
  action          String        // e.g., "UPDATE_PASSWORD", "CHANGE_PLAN"
  entity          String        // e.g., "USER", "MERCHANT_STORE"
  entityId        String?       // ID of the affected entity
  metadata        String?       @db.Text // JSON string for detailed changes (before/after)
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())

  admin           User          @relation("AdminActions", fields: [adminId], references: [id])
}

model Task {
  id              String         @id @default(cuid())
  merchantStoreId String
  creatorId       String
  assigneeId      String?
  orderId         String?
  customerId      String?
  title           String
  description     String?        @db.Text
  priority        String         @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status          String         @default("PENDING_CONFIRMATION") // PENDING_CONFIRMATION, ACTIVE, IN_PROGRESS, COMPLETED, CANCELLED
  deadline        DateTime?
  confirmedAt     DateTime?
  completedAt     DateTime?
  aiMetadata      String?        @db.Text // JSON string for AI context
  attachments     String?        @db.Text // JSON string for file attachments
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  readableId      String?        @unique

  merchantStore   MerchantStore  @relation(fields: [merchantStoreId], references: [id])
  creator         User           @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee        User?          @relation("TaskAssignee", fields: [assigneeId], references: [id])
  order           Order?         @relation("OrderTasks", fields: [orderId], references: [id])
  customer        Customer?      @relation(fields: [customerId], references: [id])
  messages        TaskMessage[]
  activities      TaskActivity[]
  workLogs        StaffWorkLog[]
}

model TaskMessage {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String   @db.Text
  isAi      Boolean  @default(false)
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model TaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  userId    String?
  type      String   // STATUS_CHANGE, COMMENT, ASSIGNEE_CHANGE, DEADLINE_CHANGE
  message   String
  metadata  String?  @db.Text
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

model MerchantSequence {
  id              String        @id @default(cuid())
  merchantStoreId String        @unique
  customerSeq     Int           @default(0)
  orderSeq        Int           @default(0)
  taskSeq         Int           @default(0)
  staffSeq        Int           @default(0)
  merchantStore   MerchantStore @relation(fields: [merchantStoreId], references: [id])
}

model SystemSequence {
  id            String @id @default("GLOBAL")
  merchantCount Int    @default(0)
  adminCount    Int    @default(0)
}
